{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "landing", "takeoff", "settings"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:allow-execute",
    "shell:allow-open",
    "log:default",
    "dialog:default",
    "core:window:allow-close",
    "core:window:allow-show",
    "window-state:default"
  ]
}
