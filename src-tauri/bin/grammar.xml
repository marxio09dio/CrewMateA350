<?xml version="1.0" encoding="UTF-8"?>
<grammar
  version="1.0"
  xml:lang="en-US"
  xmlns="http://www.w3.org/2001/06/grammar"
  tag-format="semantics/1.0"
  root="TOPLEVEL"
>
  <!-- ═══════════════════════════════════════════════════════════════════════════
       TOPLEVEL
  ════════════════════════════════════════════════════════════════════════════ -->
  <rule id="TOPLEVEL" scope="public">
    <one-of>
      <item>
        <ruleref uri="#FO_COMMANDS" />
        <tag>out.ActionRuleId="FO_COMMANDS"; out.CmdId=rules.FO_COMMANDS.pid; out.CmdValue=rules.FO_COMMANDS.cval;</tag>
      </item>
      <item>
        <ruleref uri="#FMA_CALLOUTS" />
        <tag>out.ActionRuleId="FMA_CALLOUTS"; out.CmdId=rules.FMA_CALLOUTS.pid; out.CmdValue=rules.FMA_CALLOUTS.cval;</tag>
      </item>
      <item>
        <ruleref uri="#DISCRETE_COMMANDS" />
        <tag>out.ActionRuleId="DISCRETE_COMMANDS"; out.CmdId=rules.DISCRETE_COMMANDS.pid;</tag>
      </item>
    </one-of>
  </rule>

  <!-- ═══════════════════════════════════════════════════════════════════════════
       FO_COMMANDS  (parameterized — cval carries the numeric value)

       pid  command                    cval
        1   heading                    "NNN"
        2   flight level               "NNN"
        3   altitude feet              "NNNNN"   e.g. "08000"
        4   speed                      "NNN"
        5   com frequency              "NNNNNN"  e.g. "118300"
        6   transponder                "NNNN"
        7   altimeter                  "NNNN"    inHg or hPa — dispatcher disambiguates
        8   fuel kg                    "TT|HHH"  e.g. "60|600" → 60600 kg
        9   fuel kg balanced           "TT|HHH"
       10   fuel lbs                   "TT|HHH"
       11   fuel lbs balanced          "TT|HHH"
       12   fuel tons                  "NN.N"
       13   fuel tons balanced         "NN.N"
       14   takeoff data flex          "V1|VR|V2|FLX|temp"
       15   takeoff data toga          "V1|VR|V2|TOGA|"
       16   missed approach auto       "AUTO"
       17   missed approach feet       "NNNNN"
       18   missed approach FL         "NNN"
       19   baro minimums              "NNN[N]"  e.g. "450", "1000"
       20   radio minimums             "NNN[N]"  e.g. "160", "200"
  ════════════════════════════════════════════════════════════════════════════ -->
  <rule id="FO_COMMANDS">
    <one-of>
      <!-- Heading -->
      <item>
        <item repeat="0-1">
          <ruleref uri="#VERB" />
        </item>
        <one-of>
          <item>heading</item>
        </one-of>
        <ruleref uri="#HDG_SPD_FL_VALUE" />
        <tag>out.pid="1"; out.cval=rules.HDG_SPD_FL_VALUE;</tag>
      </item>

      <!-- Flight level -->
      <item>
        <item repeat="0-1">
          <ruleref uri="#VERB" />
        </item>
        <item>flight level</item>
        <ruleref uri="#HDG_SPD_FL_VALUE" />
        <tag>out.pid="2"; out.cval=rules.HDG_SPD_FL_VALUE;</tag>
      </item>

      <!-- Altitude feet -->
      <item>
        <one-of>
          <item>
            <ruleref uri="#VERB" />
            <item>altitude</item>
          </item>
        </one-of>
        <ruleref uri="#ALTITUDE_VALUE" />
        <item repeat="0-1">feet</item>
        <tag>out.pid="3"; out.cval=rules.ALTITUDE_VALUE;</tag>
      </item>

      <!-- Speed -->
      <item>
        <item repeat="0-1">
          <ruleref uri="#VERB" />
        </item>
        <item>speed</item>
        <ruleref uri="#HDG_SPD_FL_VALUE" />
        <item repeat="0-1">knots</item>
        <tag>out.pid="4"; out.cval=rules.HDG_SPD_FL_VALUE;</tag>
      </item>

      <!-- COM frequency -->
      <item>
        <one-of>
          <item>tune</item>
          <item>set frequency</item>
        </one-of>
        <ruleref uri="#COM_FREQ_VALUE" />
        <tag>out.pid="5"; out.cval=rules.COM_FREQ_VALUE;</tag>
      </item>

      <!-- Altimeter — prefixed "altimeter XXXX [set]" -->
      <item>
        <item repeat="0-1">
          <ruleref uri="#VERB" />
        </item>
        <item>altimeter</item>
        <ruleref uri="#ALTIMETER_VALUE" />
        <item repeat="0-1">set</item>
        <tag>out.pid="7"; out.cval=rules.ALTIMETER_VALUE;</tag>
      </item>

      <!-- Altimeter — prefixed "qnh XXXX [set]" -->
      <item>
        <item repeat="0-1">
          <ruleref uri="#VERB" />
        </item>
        <item>qnh</item>
        <ruleref uri="#ALTIMETER_VALUE" />
        <item repeat="0-1">set</item>
        <tag>out.pid="7"; out.cval=rules.ALTIMETER_VALUE;</tag>
      </item>

      <!-- Altimeter — bare "XXX[X] set" -->
      <item>
        <ruleref uri="#ALTIMETER_VALUE" />
        <item>set</item>
        <tag>out.pid="7"; out.cval=rules.ALTIMETER_VALUE;</tag>
      </item>

      <!-- Fuel kilograms [balanced] -->
      <item>
        <item repeat="0-1">
          <one-of>
            <item>fuel quantity</item>
            <item>fuel</item>
          </one-of>
        </item>
        <ruleref uri="#FUEL_VALUE" />
        <tag>out.fv=rules.FUEL_VALUE;</tag>
        <one-of>
          <item>kilograms</item>
          <item>kilos</item>
        </one-of>
        <one-of>
          <item>balanced<tag>out.pid="9"; out.cval=out.fv;</tag></item>
          <item>
            <tag>out.pid="8"; out.cval=out.fv;</tag>
          </item>
        </one-of>
      </item>

      <!-- Fuel pounds [balanced] -->
      <item>
        <item repeat="0-1">
          <one-of>
            <item>fuel quantity</item>
            <item>fuel</item>
          </one-of>
        </item>
        <ruleref uri="#FUEL_VALUE" />
        <tag>out.fv=rules.FUEL_VALUE;</tag>
        <item>pounds</item>
        <one-of>
          <item>balanced<tag>out.pid="11"; out.cval=out.fv;</tag></item>
          <item>
            <tag>out.pid="10"; out.cval=out.fv;</tag>
          </item>
        </one-of>
      </item>

      <!-- Fuel tons [balanced] -->
      <item>
        <item repeat="0-1">
          <one-of>
            <item>fuel quantity</item>
            <item>fuel</item>
          </one-of>
        </item>
        <ruleref uri="#FUEL_TONS_VALUE" />
        <tag>out.fv=rules.FUEL_TONS_VALUE;</tag>
        <one-of>
          <item>tons</item>
          <item>metric tons</item>
        </one-of>
        <one-of>
          <item>balanced<tag>out.pid="13"; out.cval=out.fv;</tag></item>
          <item>
            <tag>out.pid="12"; out.cval=out.fv;</tag>
          </item>
        </one-of>
      </item>

      <!-- Takeoff data — flex "V1 NNN VR NNN V2 NNN flex XX" -->
      <item>
        <item>V1</item>
        <ruleref uri="#HDG_SPD_FL_VALUE" />
        <tag>out.v1=rules.HDG_SPD_FL_VALUE;</tag>
        <item>VR</item>
        <ruleref uri="#HDG_SPD_FL_VALUE" />
        <tag>out.vr=rules.HDG_SPD_FL_VALUE;</tag>
        <item>V2</item>
        <ruleref uri="#HDG_SPD_FL_VALUE" />
        <tag>out.v2=rules.HDG_SPD_FL_VALUE;</tag>
        <item>flex</item>
        <ruleref uri="#FLEX_TEMP_VALUE" />
        <tag>out.ft=rules.FLEX_TEMP_VALUE;</tag>
        <tag>out.pid="14"; out.cval=out.v1+"|"+out.vr+"|"+out.v2+"|FLX|"+out.ft;</tag>
      </item>

      <!-- Takeoff data — toga "V1 NNN VR NNN V2 NNN toga" -->
      <item>
        <item>V1</item>
        <ruleref uri="#HDG_SPD_FL_VALUE" />
        <tag>out.v1=rules.HDG_SPD_FL_VALUE;</tag>
        <item>VR</item>
        <ruleref uri="#HDG_SPD_FL_VALUE" />
        <tag>out.vr=rules.HDG_SPD_FL_VALUE;</tag>
        <item>V2</item>
        <ruleref uri="#HDG_SPD_FL_VALUE" />
        <tag>out.v2=rules.HDG_SPD_FL_VALUE;</tag>
        <item>toga</item>
        <tag>out.pid="15"; out.cval=out.v1+"|"+out.vr+"|"+out.v2+"|TOGA|";</tag>
      </item>

      <!-- Missed approach altitude — auto -->
      <item>
        <one-of>
          <item>set missed approach altitude</item>
          <item>set missed approach</item>
          <item>missed approach altitude</item>
          <item>missed approach</item>
        </one-of>
        <tag>out.pid="16"; out.cval="AUTO";</tag>
      </item>

      <!-- Missed approach altitude — explicit feet -->
      <item>
        <one-of>
          <item>set missed approach altitude</item>
          <item>set missed approach</item>
          <item>missed approach altitude</item>
          <item>missed approach</item>
        </one-of>
        <ruleref uri="#ALTITUDE_VALUE" />
        <item repeat="0-1">feet</item>
        <tag>out.pid="17"; out.cval=rules.ALTITUDE_VALUE;</tag>
      </item>

      <!-- Missed approach altitude — explicit flight level -->
      <item>
        <one-of>
          <item>set missed approach altitude</item>
          <item>set missed approach</item>
          <item>missed approach altitude</item>
          <item>missed approach</item>
        </one-of>
        <item>flight level</item>
        <ruleref uri="#HDG_SPD_FL_VALUE" />
        <tag>out.pid="18"; out.cval=rules.HDG_SPD_FL_VALUE;</tag>
      </item>

      <!-- BARO minimums — "baro four hundred fifty [feet]" → "450" -->
      <item>
        <item>baro</item>
        <ruleref uri="#MINIMUMS_VALUE" />
        <item repeat="0-1">feet</item>
        <tag>out.pid="19"; out.cval=rules.MINIMUMS_VALUE;</tag>
      </item>

      <!-- RADIO minimums — "radio one hundred sixty [feet]" → "160" -->
      <item>
        <item>radio</item>
        <ruleref uri="#MINIMUMS_VALUE" />
        <item repeat="0-1">feet</item>
        <tag>out.pid="20"; out.cval=rules.MINIMUMS_VALUE;</tag>
      </item>
    </one-of>
  </rule>

  <!-- ═══════════════════════════════════════════════════════════════════════════
       FMA_CALLOUTS
       pid always "1". cval = "thrust|vertical|lateral|combined|cat|armed|urgent"
  ════════════════════════════════════════════════════════════════════════════ -->
  <rule id="FMA_CALLOUTS">
    <one-of>
      <!-- urgent standalones -->
      <item>alpha floor<tag>out.pid="1"; out.cval="||||||A.FLOOR";</tag></item>
      <item>toga lock<tag>out.pid="1"; out.cval="||||||TOGA LK";</tag></item>

      <!-- compound: optional thrust + vertical/combined/lateral + optional cat + optional armed -->
      <item>
        <tag>out.th=""; out.vt=""; out.lt=""; out.cb=""; out.ct=""; out.ar="";</tag>
        <item repeat="0-1">check</item>
        <item repeat="0-1">
          <ruleref uri="#FMA_THRUST_MODE" />
          <tag>out.th=rules.FMA_THRUST_MODE;</tag>
        </item>
        <one-of>
          <item>
            <ruleref uri="#FMA_COMBINED_MODE" />
            <tag>out.cb=rules.FMA_COMBINED_MODE;</tag>
          </item>
          <item>
            <ruleref uri="#FMA_VERTICAL_MODE" />
            <tag>out.vt=rules.FMA_VERTICAL_MODE;</tag>
            <item repeat="0-1">
              <ruleref uri="#FMA_LATERAL_MODE" />
              <tag>out.lt=rules.FMA_LATERAL_MODE;</tag>
            </item>
          </item>
          <item>
            <ruleref uri="#FMA_LATERAL_MODE" />
            <tag>out.lt=rules.FMA_LATERAL_MODE;</tag>
          </item>
        </one-of>
        <item repeat="0-1">
          <ruleref uri="#FMA_APPROACH_CAT" />
          <tag>out.ct=rules.FMA_APPROACH_CAT;</tag>
        </item>
        <item repeat="0-1">
          <ruleref uri="#FMA_ARMED" />
          <tag>out.ar=rules.FMA_ARMED;</tag>
        </item>
        <tag>out.pid="1"; out.cval=out.th+"|"+out.vt+"|"+out.lt+"|"+out.cb+"|"+out.ct+"|"+out.ar+"|";</tag>
      </item>

      <!-- thrust only ± armed -->
      <item>
        <tag>out.ar="";</tag>
        <ruleref uri="#FMA_THRUST_MODE" />
        <tag>out.th=rules.FMA_THRUST_MODE;</tag>
        <item repeat="0-1">
          <ruleref uri="#FMA_ARMED" />
          <tag>out.ar=rules.FMA_ARMED;</tag>
        </item>
        <tag>out.pid="1"; out.cval=out.th+"|||||"+out.ar+"|";</tag>
      </item>
    </one-of>
  </rule>

  <!-- FMA column 1: thrust modes -->
  <rule id="FMA_THRUST_MODE">
    <one-of>
      <item>toga<tag>out="TOGA";</tag></item>
      <item>thrust climb<tag>out="THR CLB";</tag></item>
      <item>thrust idle<tag>out="THR IDLE";</tag></item>
      <item>thrust max continuous<tag>out="THR MCT";</tag></item>
      <item>speed<tag>out="SPEED";</tag></item>
      <item>mach<tag>out="MACH";</tag></item>
      <item>lever climb<tag>out="LVR CLB";</tag></item>
      <item>lever max continuous<tag>out="LVR MCT";</tag></item>
      <item>lever asymmetric<tag>out="LVR ASYM";</tag></item>
      <item>man toga<tag>out="MAN TOGA";</tag></item>
      <item>manual toga<tag>out="MAN TOGA";</tag></item>
      <item>man max continuous<tag>out="MAN MCT";</tag></item>
      <item>manual max continuous<tag>out="MAN MCT";</tag></item>
      <item>
        <one-of>
          <item>man flex</item>
          <item>manual flex</item>
        </one-of>
        <ruleref uri="#FLEX_TEMP_VALUE" />
        <tag>out="MAN FLX/"+rules.FLEX_TEMP_VALUE;</tag>
      </item>
    </one-of>
  </rule>

  <!-- FMA column 2: vertical modes -->
  <rule id="FMA_VERTICAL_MODE">
    <one-of>
      <item>srs<tag>out="SRS";</tag></item>
      <item>speed reference system<tag>out="SRS";</tag></item>
      <item>alt hold<tag>out="ALT";</tag></item>
      <item>altitude hold<tag>out="ALT";</tag></item>
      <item>alt star<tag>out="ALT*";</tag></item>
      <item>altitude star<tag>out="ALT*";</tag></item>
      <item>altitude capture<tag>out="ALT*";</tag></item>
      <item>alt cruise<tag>out="ALT CRZ";</tag></item>
      <item>altitude cruise<tag>out="ALT CRZ";</tag></item>
      <item>alt constraint<tag>out="ALT CST";</tag></item>
      <item>altitude constraint<tag>out="ALT CST";</tag></item>
      <item>climb<tag>out="CLB";</tag></item>
      <item>descent<tag>out="DES";</tag></item>
      <item>open climb<tag>out="OP CLB";</tag></item>
      <item>open descent<tag>out="OP DES";</tag></item>
      <item>expedite climb<tag>out="EXP CLB";</tag></item>
      <item>expedite descent<tag>out="EXP DES";</tag></item>
      <item>glideslope<tag>out="G/S";</tag></item>
      <item>glideslope star<tag>out="G/S*";</tag></item>
      <item>glideslope capture<tag>out="G/S*";</tag></item>
      <item>final<tag>out="FINAL";</tag></item>
      <item>vertical speed<tag>out="V/S";</tag></item>
      <item>flight path angle<tag>out="FPA";</tag></item>
    </one-of>
  </rule>

  <!-- FMA column 3: lateral modes -->
  <rule id="FMA_LATERAL_MODE">
    <one-of>
      <item>runway<tag>out="RWY";</tag></item>
      <item>runway track<tag>out="RWY TRK";</tag></item>
      <item>go around track<tag>out="GA TRK";</tag></item>
      <item>hdg<tag>out="HDG";</tag></item>
      <item>heading<tag>out="HDG";</tag></item>
      <item>track<tag>out="TRACK";</tag></item>
      <item>nav<tag>out="NAV";</tag></item>
      <item>loc<tag>out="LOC";</tag></item>
      <item>loc star<tag>out="LOC*";</tag></item>
      <item>localizer<tag>out="LOC";</tag></item>
      <item>localizer star<tag>out="LOC*";</tag></item>
      <item>localizer capture<tag>out="LOC*";</tag></item>
      <item>approach nav<tag>out="APP NAV";</tag></item>
    </one-of>
  </rule>

  <!-- FMA cols 2+3: combined modes -->
  <rule id="FMA_COMBINED_MODE">
    <one-of>
      <item>land<tag>out="LAND";</tag></item>
      <item>flare<tag>out="FLARE";</tag></item>
      <item>roll out<tag>out="ROLL OUT";</tag></item>
      <item>final app<tag>out="FINAL APP";</tag></item>
    </one-of>
  </rule>

  <!-- FMA column 4: approach category -->
  <rule id="FMA_APPROACH_CAT">
    <one-of>
      <item>cat one<tag>out="CAT 1";</tag></item>
      <item>cat two<tag>out="CAT 2";</tag></item>
      <item>cat three single<tag>out="CAT 3 SINGLE";</tag></item>
      <item>cat three dual<tag>out="CAT 3 DUAL";</tag></item>
    </one-of>
  </rule>

  <!-- FMA column 5: autothrust armed -->
  <rule id="FMA_ARMED">
    <item>autothrust</item>
    <item repeat="0-1">blue</item>
    <tag>out="A/THR";</tag>
  </rule>

  <!-- ═══════════════════════════════════════════════════════════════════════════
       DISCRETE_COMMANDS  (no numeric value)
  ════════════════════════════════════════════════════════════════════════════ -->
  <rule id="DISCRETE_COMMANDS">
    <one-of>
      <!-- Gear -->
      <item>gear up<tag>out.pid="1";</tag></item>
      <item>gear down<tag>out.pid="2";</tag></item>
      <!-- Flaps -->
      <item>flaps zero<tag>out.pid="3";</tag></item>
      <item>flaps one<tag>out.pid="4";</tag></item>
      <item>flaps two<tag>out.pid="5";</tag></item>
      <item>flaps three<tag>out.pid="6";</tag></item>
      <item>flaps full<tag>out.pid="7";</tag></item>
      <!-- Autopilot -->
      <item>autopilot engage<tag>out.pid="8";</tag></item>
      <item>auto pilot on<tag>out.pid="8";</tag></item>
      <item>auto pilot one on<tag>out.pid="8";</tag></item>
      <item>autopilot disconnect<tag>out.pid="9";</tag></item>
      <!-- Lights -->
      <item>landing lights on<tag>out.pid="12";</tag></item>
      <item>takeoff lights on<tag>out.pid="69";</tag></item>
      <item>landing lights off<tag>out.pid="13";</tag></item>
      <item>strobe lights on<tag>out.pid="14";</tag></item>
      <item>strobe lights auto<tag>out.pid="15";</tag></item>
      <item>strobe lights off<tag>out.pid="16";</tag></item>
      <item>taxi lights on<tag>out.pid="17";</tag></item>
      <item>taxi lights off<tag>out.pid="18";</tag></item>
      <!-- Flight director -->
      <item>flight director on<tag>out.pid="19";</tag></item>
      <item>bird on<tag>out.pid="67";</tag></item>
      <item>flight director off<tag>out.pid="20";</tag></item>
      <item>bird off<tag>out.pid="68";</tag></item>
      <item>flight director off bird on<tag>out.pid="21";</tag></item>
      <!-- Checklists -->
      <item>cockpit preparation checklist<tag>out.pid="22";</tag></item>
      <item>departure change checklist<tag>out.pid="23";</tag></item>
      <item>before start checklist<tag>out.pid="24";</tag></item>
      <item>before start procedure<tag>out.pid="24";</tag></item>
      <item>before start flow<tag>out.pid="24";</tag></item>
      <item>after start checklist<tag>out.pid="25";</tag></item>
      <item>taxi checklist<tag>out.pid="26";</tag></item>
      <item>lineup checklist<tag>out.pid="27";</tag></item>
      <item>before takeoff procedure<tag>out.pid="27";</tag></item>
      <item>approach checklist<tag>out.pid="28";</tag></item>
      <item>landing checklist<tag>out.pid="29";</tag></item>
      <item>parking checklist<tag>out.pid="30";</tag></item>
      <item>secure aircraft checklist<tag>out.pid="31";</tag></item>
      <item>cancel checklist<tag>out.pid="32";</tag></item>
      <item>stop checklist<tag>out.pid="32";</tag></item>
      <item>abort checklist<tag>out.pid="32";</tag></item>
      <!-- Prepare / setup -->
      <item>lets prepare the aircraft<tag>out.pid="33";</tag></item>
      <item>lets prepare the flight<tag>out.pid="33";</tag></item>
      <item>lets set up the aircraft<tag>out.pid="33";</tag></item>
      <!-- Engine start -->
      <item>starting engine one<tag>out.pid="34";</tag></item>
      <item>starting engine number one<tag>out.pid="34";</tag></item>
      <item>starting one<tag>out.pid="34";</tag></item>
      <item>starting number one<tag>out.pid="34";</tag></item>
      <item>starting engine two<tag>out.pid="35";</tag></item>
      <item>starting engine number two<tag>out.pid="35";</tag></item>
      <item>starting two<tag>out.pid="35";</tag></item>
      <item>starting number two<tag>out.pid="35";</tag></item>
      <item>start the apu<tag>out.pid="36";</tag></item>
      <item>start apu<tag>out.pid="36";</tag></item>
      <!-- Clear / side checks -->
      <item>clear left<tag>out.pid="37";</tag></item>
      <item>clear on the left<tag>out.pid="37";</tag></item>
      <item>left side clear<tag>out.pid="37";</tag></item>
      <item>clear left side<tag>out.pid="37";</tag></item>
      <!-- ATC / clearance -->
      <item>runway entry procedure<tag>out.pid="38";</tag></item>
      <item>clear to line up<tag>out.pid="39";</tag></item>
      <item>clear for takeoff<tag>out.pid="40";</tag></item>
      <item>takeoff<tag>out.pid="41";</tag></item>
      <item>approach<tag>out.pid="42";</tag></item>
      <!-- Shutdown -->
      <item>shutdown procedure<tag>out.pid="43";</tag></item>
      <item>shutdown<tag>out.pid="43";</tag></item>
      <!-- Flight controls -->
      <item>flight controls check<tag>out.pid="44";</tag></item>
      <!-- Anti ice -->
      <item>wing anti ice on<tag>out.pid="45";</tag></item>
      <item>wing anti ice off<tag>out.pid="46";</tag></item>
      <item>engine anti ice on<tag>out.pid="47";</tag></item>
      <item>engine anti ice off<tag>out.pid="48";</tag></item>
      <!-- Wipers -->
      <item>wipers off<tag>out.pid="49";</tag></item>
      <item>wipers slow<tag>out.pid="50";</tag></item>
      <item>wipers fast<tag>out.pid="51";</tag></item>
      <item>wipers slow intermittent<tag>out.pid="52";</tag></item>
      <item>wipers medium intermittent<tag>out.pid="53";</tag></item>
      <item>wipers fast intermittent<tag>out.pid="54";</tag></item>
      <!-- Seat belts -->
      <item>seat belts on<tag>out.pid="55";</tag></item>
      <item>seat belts off<tag>out.pid="56";</tag></item>
      <item>seat belts auto<tag>out.pid="57";</tag></item>
      <!-- Parking -->
      <item>chocks in place<tag>out.pid="58";</tag></item>
      <item>parking brake set<tag>out.pid="59";</tag></item>
      <!-- Cabin crew -->
      <item>cabin crew arm slides and cross check<tag>out.pid="60";</tag></item>
      <item>cabin crew arm slides<tag>out.pid="60";</tag></item>
      <!-- Brake -->
      <item>brake check<tag>out.pid="61";</tag></item>
      <!-- TCAS -->
      <item>tara<tag>out.pid="62";</tag></item>
      <item>ta ra<tag>out.pid="62";</tag></item>
      <item>t a r a<tag>out.pid="62";</tag></item>
      <item>ta only<tag>out.pid="63";</tag></item>
      <!-- Navigation -->
      <item>set standard<tag>out.pid="64";</tag></item>
      <item>set runway track<tag>out.pid="65";</tag></item>
      <!-- Transponder -->
      <item>set transponder auto<tag>out.pid="66";</tag></item>
      <!-- Generic responses / checklist replies -->
      <item>confirm<tag>out.pid="70";</tag></item>
      <item>confirmed<tag>out.pid="70";</tag></item>
      <item>negative<tag>out.pid="71";</tag></item>
      <item>set<tag>out.pid="72";</tag></item>
      <item>set and checked<tag>out.pid="72";</tag></item>
      <item>checked<tag>out.pid="73";</tag></item>
      <item>check<tag>out.pid="73";</tag></item>
      <item>on<tag>out.pid="74";</tag></item>
      <item>off<tag>out.pid="75";</tag></item>
      <item>armed<tag>out.pid="76";</tag></item>
      <item>auto<tag>out.pid="77";</tag></item>
      <item>normal<tag>out.pid="78";</tag></item>
      <item>retracted<tag>out.pid="79";</tag></item>
      <item>down<tag>out.pid="80";</tag></item>
      <item>secured<tag>out.pid="81";</tag></item>
      <item>secure<tag>out.pid="81";</tag></item>
      <item>removed<tag>out.pid="82";</tag></item>
      <item>released<tag>out.pid="83";</tag></item>
      <item>received<tag>out.pid="84";</tag></item>
      <item>started<tag>out.pid="85";</tag></item>
      <item>running<tag>out.pid="86";</tag></item>
      <item>advised<tag>out.pid="87";</tag></item>
      <item>signaled<tag>out.pid="88";</tag></item>
      <item>stop<tag>out.pid="89";</tag></item>
      <item>rto<tag>out.pid="89";</tag></item>
      <item>medium<tag>out.pid="90";</tag></item>
      <item>btv<tag>out.pid="91";</tag></item>
      <item>engines on<tag>out.pid="92";</tag></item>
      <item>engines on wings on<tag>out.pid="93";</tag></item>
      <item>on supplied by apu<tag>out.pid="94";</tag></item>
      <!-- Config -->
      <item>config one<tag>out.pid="95";</tag></item>
      <item>config one plus f<tag>out.pid="96";</tag></item>
      <item>config two<tag>out.pid="97";</tag></item>
      <item>config three<tag>out.pid="98";</tag></item>
      <!-- Go around / abort / land -->
      <item>go around flaps<tag>out.pid="99";</tag></item>
      <item>abort takeoff<tag>out.pid="100";</tag></item>
      <item>continue<tag>out.pid="101";</tag></item>
      <!-- autopilot commands -->
      <item>pull altitude<tag>out.pid="102";</tag></item>
      <item>manage altitude<tag>out.pid="103";</tag></item>
      <item>pull speed<tag>out.pid="104";</tag></item>
      <item>manage speed<tag>out.pid="105";</tag></item>
      <item>pull heading<tag>out.pid="106";</tag></item>
      <item>manage nav<tag>out.pid="107";</tag></item>
      <item>pull altitude<tag>out.pid="108";</tag></item>
      <item>manage altitude<tag>out.pid="109";</tag></item>
      <item>push to level off<tag>out.pid="110";</tag></item>
      <item>arm approach<tag>out.pid="111";</tag></item>
      <item>arm localizer<tag>out.pid="112";</tag></item>
