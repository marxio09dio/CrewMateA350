  <!-- ═══════════════════════════════════════════════════════════════════════════
       SHARED VERB
  ════════════════════════════════════════════════════════════════════════════ -->
  <rule id="VERB">
    <one-of>
      <item>set</item>
      <item>pull</item>
    </one-of>
  </rule>

  <!-- ═══════════════════════════════════════════════════════════════════════════
       NUMBER PRIMITIVES
  ════════════════════════════════════════════════════════════════════════════ -->

  <!-- Single digit 0-9 -->
  <rule id="NUMBERS">
    <one-of>
      <item>zero<tag>out="0";</tag></item>
      <item>one<tag>out="1";</tag></item>
      <item>two<tag>out="2";</tag></item>
      <item>three<tag>out="3";</tag></item>
      <item>four<tag>out="4";</tag></item>
      <item>five<tag>out="5";</tag></item>
      <item>six<tag>out="6";</tag></item>
      <item>seven<tag>out="7";</tag></item>
      <item>eight<tag>out="8";</tag></item>
      <item>nine<tag>out="9";</tag></item>
      <item>niner<tag>out="9";</tag></item>
    </one-of>
  </rule>

  <!-- Ones words 1-9 (no zero) -->
  <rule id="ONES_WORD">
    <one-of>
      <item>one<tag>out="1";</tag></item>
      <item>two<tag>out="2";</tag></item>
      <item>three<tag>out="3";</tag></item>
      <item>four<tag>out="4";</tag></item>
      <item>five<tag>out="5";</tag></item>
      <item>six<tag>out="6";</tag></item>
      <item>seven<tag>out="7";</tag></item>
      <item>eight<tag>out="8";</tag></item>
      <item>nine<tag>out="9";</tag></item>
    </one-of>
  </rule>

  <!-- Teens 10-19 -->
  <rule id="TEEN_WORD">
    <one-of>
      <item>ten<tag>out="10";</tag></item>
      <item>eleven<tag>out="11";</tag></item>
      <item>twelve<tag>out="12";</tag></item>
      <item>thirteen<tag>out="13";</tag></item>
      <item>fourteen<tag>out="14";</tag></item>
      <item>fifteen<tag>out="15";</tag></item>
      <item>sixteen<tag>out="16";</tag></item>
      <item>seventeen<tag>out="17";</tag></item>
      <item>eighteen<tag>out="18";</tag></item>
      <item>nineteen<tag>out="19";</tag></item>
    </one-of>
  </rule>

  <!-- Tens words → leading digit: "sixty" → "6" -->
  <rule id="TENS_WORD">
    <one-of>
      <item>twenty<tag>out="2";</tag></item>
      <item>thirty<tag>out="3";</tag></item>
      <item>forty<tag>out="4";</tag></item>
      <item>fifty<tag>out="5";</tag></item>
      <item>sixty<tag>out="6";</tag></item>
      <item>seventy<tag>out="7";</tag></item>
      <item>eighty<tag>out="8";</tag></item>
      <item>ninety<tag>out="9";</tag></item>
    </one-of>
  </rule>

  <!-- 3-digit value: "two seven zero" → "270" -->
  <rule id="HDG_SPD_FL_VALUE">
    <ruleref uri="#NUMBERS" />
    <tag>out.a=rules.NUMBERS;</tag>
    <ruleref uri="#NUMBERS" />
    <tag>out.b=rules.NUMBERS;</tag>
    <ruleref uri="#NUMBERS" />
    <tag>out=out.a+out.b+rules.NUMBERS;</tag>
  </rule>

  <!-- 3-or-4-digit altimeter value
       4 digits: inHg   "two nine nine two"  → "2992"  (dispatcher checks 2700-3100)
       3 digits: hPa    "nine nine eight"    → "998"   (dispatcher checks 900-1100)
       FOUR_DIGIT_VALUE is kept for transponder (always 4 digits). -->
  <rule id="ALTIMETER_VALUE">
    <one-of>
      <!-- 4-digit inHg: digit by digit -->
      <item>
        <ruleref uri="#NUMBERS" />
        <tag>out.a=rules.NUMBERS;</tag>
        <ruleref uri="#NUMBERS" />
        <tag>out.b=rules.NUMBERS;</tag>
        <ruleref uri="#NUMBERS" />
        <tag>out.c=rules.NUMBERS;</tag>
        <ruleref uri="#NUMBERS" />
        <tag>out=out.a+out.b+out.c+rules.NUMBERS;</tag>
      </item>
      <!-- 3-digit hPa: digit by digit -->
      <item>
        <ruleref uri="#NUMBERS" />
        <tag>out.a=rules.NUMBERS;</tag>
        <ruleref uri="#NUMBERS" />
        <tag>out.b=rules.NUMBERS;</tag>
        <ruleref uri="#NUMBERS" />
        <tag>out=out.a+out.b+rules.NUMBERS;</tag>
      </item>
    </one-of>
  </rule>

  <!-- 4-digit value: "two nine nine two" → "2992" -->
  <rule id="FOUR_DIGIT_VALUE">
    <ruleref uri="#NUMBERS" />
    <tag>out.a=rules.NUMBERS;</tag>
    <ruleref uri="#NUMBERS" />
    <tag>out.b=rules.NUMBERS;</tag>
    <ruleref uri="#NUMBERS" />
    <tag>out.c=rules.NUMBERS;</tag>
    <ruleref uri="#NUMBERS" />
    <tag>out=out.a+out.b+out.c+rules.NUMBERS;</tag>
  </rule>

  <!-- Hundreds component: "five hundred" → "500" -->
  <rule id="ALTV_HUNDREDS">
    <one-of>
      <item>one hundred<tag>out="100";</tag></item>
      <item>two hundred<tag>out="200";</tag></item>
      <item>three hundred<tag>out="300";</tag></item>
      <item>four hundred<tag>out="400";</tag></item>
      <item>five hundred<tag>out="500";</tag></item>
      <item>six hundred<tag>out="600";</tag></item>
      <item>seven hundred<tag>out="700";</tag></item>
      <item>eight hundred<tag>out="800";</tag></item>
      <item>nine hundred<tag>out="900";</tag></item>
    </one-of>
  </rule>

  <!-- Thousands component for altitude 1-59: "twelve" → "12", "eight" → "08" -->
  <rule id="ALTV_THOUSANDS">
    <one-of>
      <item>one<tag>out="01";</tag></item>
      <item>two<tag>out="02";</tag></item>
      <item>three<tag>out="03";</tag></item>
      <item>four<tag>out="04";</tag></item>
      <item>five<tag>out="05";</tag></item>
      <item>six<tag>out="06";</tag></item>
      <item>seven<tag>out="07";</tag></item>
      <item>eight<tag>out="08";</tag></item>
      <item>nine<tag>out="09";</tag></item>
      <item>
        <ruleref uri="#TEEN_WORD" />
        <tag>out=rules.TEEN_WORD;</tag>
      </item>
      <item>
        <ruleref uri="#TENS_WORD" />
        <tag>out.t=rules.TENS_WORD;</tag>
        <ruleref uri="#ONES_WORD" />
        <tag>out=out.t+rules.ONES_WORD;</tag>
      </item>
      <item>twenty<tag>out="20";</tag></item>
      <item>thirty<tag>out="30";</tag></item>
      <item>forty<tag>out="40";</tag></item>
      <item>fifty<tag>out="50";</tag></item>
    </one-of>
  </rule>

  <!-- Altitude value: "twelve thousand five hundred" → "12500" -->
  <rule id="ALTITUDE_VALUE">
    <ruleref uri="#ALTV_THOUSANDS" />
    <tag>out.t=rules.ALTV_THOUSANDS; out.h="000";</tag>
    <item>thousand</item>
    <item repeat="0-1">
      <ruleref uri="#ALTV_HUNDREDS" />
      <tag>out.h=rules.ALTV_HUNDREDS;</tag>
    </item>
    <tag>out=out.t+out.h;</tag>
  </rule>

  <!-- COM frequency: "one one eight decimal three zero zero" → "118300" -->
  <rule id="COM_FREQ_VALUE">
    <ruleref uri="#NUMBERS" />
    <tag>out.a=rules.NUMBERS;</tag>
    <ruleref uri="#NUMBERS" />
    <tag>out.b=rules.NUMBERS;</tag>
    <ruleref uri="#NUMBERS" />
    <tag>out.c=rules.NUMBERS;</tag>
    <one-of>
      <item>decimal</item>
      <item>point</item>
    </one-of>
    <ruleref uri="#NUMBERS" />
    <tag>out.d=rules.NUMBERS;</tag>
    <ruleref uri="#NUMBERS" />
    <tag>out.e=rules.NUMBERS;</tag>
    <ruleref uri="#NUMBERS" />
    <tag>out=out.a+out.b+out.c+out.d+out.e+rules.NUMBERS;</tag>
  </rule>

  <!-- Thousands component for fuel 1-99 -->
  <rule id="FUEL_THOUSANDS">
    <one-of>
      <item>
        <ruleref uri="#ONES_WORD" />
        <tag>out=rules.ONES_WORD;</tag>
      </item>
      <item>
        <ruleref uri="#TEEN_WORD" />
        <tag>out=rules.TEEN_WORD;</tag>
      </item>
      <item>
        <ruleref uri="#TENS_WORD" />
        <tag>out.t=rules.TENS_WORD;</tag>
        <ruleref uri="#ONES_WORD" />
        <tag>out=out.t+rules.ONES_WORD;</tag>
      </item>
      <item>twenty<tag>out="20";</tag></item>
      <item>thirty<tag>out="30";</tag></item>
      <item>forty<tag>out="40";</tag></item>
      <item>fifty<tag>out="50";</tag></item>
      <item>sixty<tag>out="60";</tag></item>
      <item>seventy<tag>out="70";</tag></item>
      <item>eighty<tag>out="80";</tag></item>
      <item>ninety<tag>out="90";</tag></item>
    </one-of>
  </rule>

  <!-- Fuel kg/lbs value: "sixty thousand six hundred" → "60|600" -->
  <rule id="FUEL_VALUE">
    <one-of>
      <item>
        <ruleref uri="#FUEL_THOUSANDS" />
        <tag>out.t=rules.FUEL_THOUSANDS;</tag>
        <item>thousand</item>
        <ruleref uri="#ALTV_HUNDREDS" />
        <tag>out=out.t+"|"+rules.ALTV_HUNDREDS;</tag>
      </item>
      <item>
        <ruleref uri="#FUEL_THOUSANDS" />
        <item>thousand</item>
        <tag>out=rules.FUEL_THOUSANDS+"|000";</tag>
      </item>
      <item>
        <ruleref uri="#ALTV_HUNDREDS" />
        <tag>out="0|"+rules.ALTV_HUNDREDS;</tag>
      </item>
    </one-of>
  </rule>

  <!-- Fuel tons: "eighteen point five" → "18.5" -->
  <rule id="FUEL_TONS_VALUE">
    <ruleref uri="#FUEL_THOUSANDS" />
    <tag>out.w=rules.FUEL_THOUSANDS;</tag>
    <item>point</item>
    <ruleref uri="#NUMBERS" />
    <tag>out=out.w+"."+rules.NUMBERS;</tag>
  </rule>

  <!-- ─── Minimums value ───────────────────────────────────────────────────────
       Supports BARO and RADIO minimums announced by the PF per FCOM.
       Examples:
         "baro four hundred fifty three feet"          → pid 19, cval "453"
         "radio six hundred thirty four feet"          → pid 20, cval "634"
         "baro one thousand two hundred thirty four"   → pid 19, cval "1234"
         "baro one thousand feet"                      → pid 19, cval "1000"
         "radio fifty feet"                            → pid 20, cval "50"

       Value structure:
         sub-hundred   : MIN_BELOW_100          → "50", "53", "13"
         N hundred     : MIN_H_LEAD + hundred + [MIN_BELOW_100]  → "400", "453"
         N thousand    : MIN_H_LEAD + thousand + [MIN_H_LEAD + hundred + [MIN_BELOW_100]]

       MIN_H_LEAD    — single leading digit "1"-"9"
       MIN_BELOW_100 — two-char string "10"-"99" (teens, pure tens, tens+ones)
  ──────────────────────────────────────────────────────────────────────────── -->
  <rule id="MINIMUMS_VALUE">
    <one-of>
      <!-- pure sub-hundred: CAT III DH values like "fifty" or "eighty" -->
      <item>
        <ruleref uri="#MIN_BELOW_100" />
        <tag>out=rules.MIN_BELOW_100;</tag>
      </item>

      <!-- N hundred [+ sub-hundred]: "four hundred fifty three" → "4"+"53" = "453" -->
      <item>
        <ruleref uri="#MIN_H_LEAD" />
        <tag>out.h=rules.MIN_H_LEAD; out.r="00";</tag>
        <item>hundred</item>
        <item repeat="0-1">
          <ruleref uri="#MIN_BELOW_100" />
          <tag>out.r=rules.MIN_BELOW_100;</tag>
        </item>
        <tag>out=out.h+out.r;</tag>
      </item>

      <!-- N thousand [+ N hundred [+ sub-hundred]]:
           "one thousand two hundred thirty four" → "1"+"2"+"34" = "1234"
           "one thousand five hundred"            → "1"+"5"+"00" = "1500"
           "one thousand"                         → "1"+"000"    = "1000" -->
      <item>
        <ruleref uri="#MIN_H_LEAD" />
        <tag>out.th=rules.MIN_H_LEAD; out.rest="000";</tag>
        <item>thousand</item>
        <item repeat="0-1">
          <ruleref uri="#MIN_H_LEAD" />
          <tag>out.hh=rules.MIN_H_LEAD; out.r2="00";</tag>
          <item>hundred</item>
          <item repeat="0-1">
            <ruleref uri="#MIN_BELOW_100" />
            <tag>out.r2=rules.MIN_BELOW_100;</tag>
          </item>
          <tag>out.rest=out.hh+out.r2;</tag>
        </item>
        <tag>out=out.th+out.rest;</tag>
      </item>
    </one-of>
  </rule>

  <!-- Single leading digit for hundreds/thousands: "one"→"1" … "nine"→"9" -->
  <rule id="MIN_H_LEAD">
    <one-of>
      <item>one<tag>out="1";</tag></item>
      <item>two<tag>out="2";</tag></item>
      <item>three<tag>out="3";</tag></item>
      <item>four<tag>out="4";</tag></item>
      <item>five<tag>out="5";</tag></item>
      <item>six<tag>out="6";</tag></item>
      <item>seven<tag>out="7";</tag></item>
      <item>eight<tag>out="8";</tag></item>
      <item>nine<tag>out="9";</tag></item>
    </one-of>
  </rule>

  <!-- Sub-hundred value as two-char string: teens, pure tens, tens+ones.
       "thirteen"    → "13"
       "fifty"       → "50"
       "fifty three" → "53"  (TENS_WORD "5" + ONES_WORD "3") -->
  <rule id="MIN_BELOW_100">
    <one-of>
      <!-- 10-19 -->
      <item>
        <ruleref uri="#TEEN_WORD" />
        <tag>out=rules.TEEN_WORD;</tag>
      </item>
      <!-- 21-99: tens + ones -->
      <item>
        <ruleref uri="#TENS_WORD" />
        <tag>out.t=rules.TENS_WORD;</tag>
        <ruleref uri="#ONES_WORD" />
        <tag>out=out.t+rules.ONES_WORD;</tag>
      </item>
      <!-- pure tens 20-90 (no trailing ones word) -->
      <item>twenty<tag>out="20";</tag></item>
      <item>thirty<tag>out="30";</tag></item>
      <item>forty<tag>out="40";</tag></item>
      <item>fifty<tag>out="50";</tag></item>
      <item>sixty<tag>out="60";</tag></item>
      <item>seventy<tag>out="70";</tag></item>
      <item>eighty<tag>out="80";</tag></item>
      <item>ninety<tag>out="90";</tag></item>
    </one-of>
  </rule>

  <!-- Flex temperature: "sixty five" or "six five" → "65" -->
  <rule id="FLEX_TEMP_VALUE">
    <one-of>
      <!-- "sixty five" — natural spoken -->
      <item>
        <ruleref uri="#FLEX_TENS" />
        <tag>out.t=rules.FLEX_TENS;</tag>
        <ruleref uri="#ONES_WORD" />
        <tag>out=out.t+rules.ONES_WORD;</tag>
      </item>
      <!-- "six five" — digit by digit -->
      <item>
        <ruleref uri="#NUMBERS" />
        <tag>out.a=rules.NUMBERS;</tag>
        <ruleref uri="#NUMBERS" />
        <tag>out=out.a+rules.NUMBERS;</tag>
      </item>
      <!-- "sixty" — pure tens -->
      <item>
        <ruleref uri="#FLEX_TENS" />
        <tag>out=rules.FLEX_TENS+"0";</tag>
      </item>
    </one-of>
  </rule>

  <!-- Tens as leading flex digit (realistic range 30-99) -->
  <rule id="FLEX_TENS">
    <one-of>
      <item>thirty<tag>out="3";</tag></item>
      <item>forty<tag>out="4";</tag></item>
      <item>fifty<tag>out="5";</tag></item>
      <item>sixty<tag>out="6";</tag></item>
      <item>seventy<tag>out="7";</tag></item>
      <item>eighty<tag>out="8";</tag></item>
      <item>ninety<tag>out="9";</tag></item>
    </one-of>
  </rule>
</grammar>
