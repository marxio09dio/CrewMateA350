{
  "id": "clear_left",
  "name": "Clear Left",
  "sound_start": "clear_right.ogg",
  "steps": [
    {
      "label": "ND SET",
      "read": "(L:INI_MAP_RANGE_FO_SWITCH)",
      "on": "0 (>L:INI_MAP_RANGE_FO_SWITCH)",
      "expect": 0
    },
    {
      "label": "Nose Wheel Light",
      "read": "(L:INI_LIGHTS_NOSE)",
      "on": "1 (>L:INI_LIGHTS_NOSE)",
      "expect": 1,
      "only_if": {
        "option": "settings.lightsControlMode",
        "one_of": ["virtual"]
      }
    }
  ]
}
