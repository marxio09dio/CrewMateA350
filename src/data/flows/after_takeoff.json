{
  "id": "after_takeoff",
  "name": "After Takeoff",
  "steps": [
    {
      "label": "Ground Spoilers",
      "read": "(L:SPOILERS_ARM_SET)",
      "on": "1 (>K:SPOILERS_ARM_OFF)",
      "expect": 0,
      "skip_verify": true
    },
    {
      "label": "APU Bleed",
      "read": "(L:INI_AIR_BLEED_APU)",
      "on": "0 (>L:INI_AIR_BLEED_APU)",
      "expect": 0
    },
    {
      "label": "APU",
      "read": "(L:INI_APU_MASTER_SWITCH)",
      "on": "0 (>L:INI_APU_MASTER_SWITCH)",
      "expect": 0
    },
    {
      "label": "pack 1",
      "read": "(L:INI_AIR_PACK1_BUTTON)",
      "on": "1 (>L:INI_AIR_PACK1_BUTTON)",
      "expect": 1
    },
    {
      "label": "pack 2",
      "read": "(L:INI_AIR_PACK2_BUTTON)",
      "on": "1 (>L:INI_AIR_PACK2_BUTTON)",
      "expect": 1
    },
    {
      "label": "Nose Wheel Light",
      "read": "(L:INI_LIGHTS_NOSE)",
      "on": "2 (>L:INI_LIGHTS_NOSE)",
      "expect": 2
    }
  ]
}
