{
  "id": "takeoff",
  "name": "Takeoff",
  "steps": [
    {
      "label": "Landing Lights",
      "read": "(L:INI_LIGHTS_LANDING)",
      "on": "1 (>L:INI_LIGHTS_LANDING)",
      "expect": 1,
      "only_if": {
        "option": "settings.lightsControlMode",
        "one_of": ["virtual"]
      }
    },
    {
      "label": "Nose Wheel Light",
      "read": "(L:INI_LIGHTS_NOSE)",
      "on": "0 (>L:INI_LIGHTS_NOSE)",
      "expect": 0,
      "only_if": {
        "option": "settings.lightsControlMode",
        "one_of": ["virtual"]
      }
    },
    {
      "label": "Chrono",
      "read": "(L:INI_FO_CHRONO_BUTTON)",
      "on": "1 (>L:INI_FO_CHRONO_BUTTON)",
      "expect": 1,
      "skip_verify": true
    }
  ]
}
