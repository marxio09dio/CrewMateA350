{
  "id": "start_engine_2",
  "name": "Start Engine 2",
  "sound_start": "starting_engine_2.ogg",
  "steps": [
    {
      "label": "Ignition Knob",
      "read": "(L:INI_IGNITION_KNOB)",
      "on": "2 (>L:INI_IGNITION_KNOB)",
      "expect": 2,
      "wait_ms": 10000
    },
    {
      "label": "Engine 2 Start",
      "read": "(L:INI_MIXTURE_RATIO2_HANDLE)",
      "on": "1 (>L:INI_MIXTURE_RATIO2_HANDLE)",
      "expect": 1
    }
  ]
}
