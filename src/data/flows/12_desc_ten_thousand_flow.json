{
  "id": "desc_ten_thousand_flow",
  "name": "Descend Ten Thousand Flow",
  "steps": [
    {
      "label": "Table",
      "read": "(L:INI_FO_TRAY_COVER_TGT)",
      "on": "0 (>L:INI_FO_TRAY_COVER_TGT)",
      "expect": 0
    },
    {
      "label": "Landing Lights",
      "read": "(L:INI_LIGHTS_LANDING)",
      "on": "1 (>L:INI_LIGHTS_LANDING)",
      "expect": 1
    },
    {
      "label": "Seat belts",
      "read": "(L:INI_SEATBELTS_SWITCH)",
      "on": "0 (>L:INI_SEATBELTS_SWITCH)",
      "expect": 0
    },
    {
      "label": "Weather Radar",
      "read": "(L:INI_WXR2_ON)",
      "on": "0 (>L:INI_WXR2_ON)",
      "expect": 0
    },
    {
      "label": "Terrain Display",
      "read": "(L:INI_TERR_ON_FO)",
      "on": "1 (>L:INI_TERR_ON_FO)",
      "expect": 1
    },
    {
      "label": "ND SET",
      "read": "(L:INI_MAP_RANGE_FO_SWITCH)",
      "on": "6 (>L:INI_MAP_RANGE_FO_SWITCH)",
      "expect": 6
    },
    {
      "label": "FO LS",
      "read": "(L:INI_LS_FO)",
      "on": "1 (>L:INI_LS_FO)",
      "expect": 1,
      "only_if": {
        "read": "(L:INI_APPROACH_TYPE)",
        "one_of": [1, 2, 5, 6]
      }
    }
  ]
}
