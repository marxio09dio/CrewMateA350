{
  "id": "cockpit_prep",
  "name": "Cockpit Preparation",
  "steps": [
    {
      "label": "Table",
      "read": "(L:INI_FO_TRAY_COVER_TGT)",
      "on": "1 (>L:INI_FO_TRAY_COVER_TGT)",
      "expect": 1
    },
    {
      "label": "Show Airports FO EFIS",
      "read": "(L:INI_SHOW_AIRPORTS2)",
      "on": "1 (>L:INI_SHOW_AIRPORTS2)",
      "expect": 1
    },
    {
      "label": "Show Constraints FO EFIS",
      "read": "(L:INI_SHOW_CONSTRAINTS2)",
      "on": "1 (>L:INI_SHOW_CONSTRAINTS2)",
      "expect": 1
    },
    {
      "label": "Show VOR1 FO EFIS",
      "read": "(L:INI_FO_VOR1_ACTIVE)",
      "on": "1 (>L:INI_FO_VOR1_ACTIVE)",
      "expect": 1
    },
    {
      "label": "Show VOR2 FO EFIS",
      "read": "(L:INI_FO_VOR2_ACTIVE)",
      "on": "1 (>L:INI_FO_VOR2_ACTIVE)",
      "expect": 1
    },
    {
      "label": "Oxy Test Hatch FO",
      "read": "(L:INI_OXYTEST_HATCH_FO)",
      "on": "1 (>L:INI_OXYTEST_HATCH_FO)",
      "expect": 1
    },
    {
      "label": "Oxy Test Hatch FO",
      "read": "(L:INI_OXYTEST_BLINKER_FO)",
      "on": "1 (>L:INI_OXYTEST_BLINKER_FO)",
      "hold_ms": 10000,
      "expect": 1
    },
    {
      "label": "Oxy Test Hatch FO",
      "read": "(L:INI_OXYTEST_HATCH_FO)",
      "on": "0 (>L:INI_OXYTEST_HATCH_FO)",
      "expect": 0
    }
  ]
}
