{
  "id": "before_takeoff",
  "name": "Before Takeoff",
  "sound_start": "cabin_takeoff.ogg",
  "sound_end": "ready.ogg",
  "steps": [
    {
      "label": "Pack 1",
      "read": "(L:INI_AIR_PACK1_BUTTON)",
      "on": "{pack1_cmd}",
      "expect": "{pack1_expect}"
    },
    {
      "label": "Pack 2",
      "read": "(L:INI_AIR_PACK2_BUTTON)",
      "on": "{pack2_cmd}",
      "expect": "{pack2_expect}"
    },
    {
      "label": "APU Bleed",
      "read": "(L:INI_AIR_BLEED_APU)",
      "on": "{apu_bleed_cmd}",
      "expect": "{apu_bleed_expect}"
    },
    {
      "label": "ND SET",
      "read": "(L:INI_MAP_RANGE_FO_SWITCH)",
      "on": "6 (>L:INI_MAP_RANGE_FO_SWITCH)",
      "expect": 6
    },
    {
      "label": "Strobes",
      "read": "(L:INI_LIGHTS_STROBE)",
      "on": "0 (>L:INI_LIGHTS_STROBE)",
      "expect": 0,
      "only_if": {
        "option": "settings.lightsControlMode",
        "one_of": ["virtual"]
      }
    }
  ]
}
