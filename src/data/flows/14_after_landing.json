{
  "id": "after_landing",
  "name": "After Landing",
  "steps": [
    {
      "label": "Flaps",
      "read": "(A:FLAPS HANDLE INDEX,Number)",
      "on": "1 (>K:FLAPS_UP)",
      "expect": 0,
      "only_if": {
        "option": "landing.antiIce",
        "one_of": ["off"]
      }
    },
    {
      "label": "APU",
      "read": "(L:INI_APU_MASTER_SWITCH)",
      "on": "{landing_apu_master_cmd}",
      "expect": "{landing_apu_master_expect}"
    },
    {
      "label": "APU Start",
      "read": "(L:INI_APU_START_BUTTON)",
      "on": "{landing_apu_start_cmd}",
      "expect": "{landing_apu_start_expect}"
    },
    {
      "label": "Engine 1 Anti Ice",
      "read": "(L:INI_ENG_ANTI_ICE1_STATE)",
      "on": "{landing_anti_ice_eng1_cmd}",
      "expect": "{landing_anti_ice_eng1_expect}"
    },
    {
      "label": "Engine 2 Anti Ice",
      "read": "(L:INI_ENG_ANTI_ICE2_STATE)",
      "on": "{landing_anti_ice_eng2_cmd}",
      "expect": "{landing_anti_ice_eng2_expect}"
    },
    {
      "label": "Weather Radar",
      "read": "(L:INI_WXR2_ON)",
      "on": "0 (>L:INI_WXR2_ON)",
      "expect": 0
    },
    {
      "label": "Terrain Display",
      "read": "(L:INI_TERR_ON_FO)",
      "on": "0 (>L:INI_TERR_ON_FO)",
      "expect": 0
    },
    {
      "label": "Landing Lights",
      "read": "(L:INI_LIGHTS_LANDING)",
      "on": "0 (>L:INI_LIGHTS_LANDING)",
      "expect": 0,
      "only_if": {
        "option": "settings.lightsControlMode",
        "one_of": ["virtual"]
      }
    },
    {
      "label": "Strobes",
      "read": "(L:INI_LIGHTS_STROBE)",
      "on": "1 (>L:INI_LIGHTS_STROBE)",
      "expect": 1,
      "only_if": {
        "option": "settings.lightsControlMode",
        "one_of": ["virtual"]
      }
    },
    {
      "label": "Nose Wheel Light",
      "read": "(L:INI_LIGHTS_NOSE)",
      "on": "1 (>L:INI_LIGHTS_NOSE)",
      "expect": 1,
      "only_if": {
        "option": "settings.lightsControlMode",
        "one_of": ["virtual"]
      }
    }
  ]
}
