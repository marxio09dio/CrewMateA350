{
  "id": "after_start",
  "name": "After Start",
  "steps": [
    {
      "label": "Ground Spoilers",
      "read": "(L:INI_SPOILERS_ARMED)",
      "on": "1 (>K:SPOILERS_ARM_SET)",
      "expect": 1
    },
    {
      "label": "Reset Rudder Trim",
      "read": "(L:RUDDER_TRIM_RESET_REQ)",
      "on": "1 (>L:RUDDER_TRIM_RESET_REQ)",
      "expect": 1,
      "skip_verify": true
    },
    {
      "label": "Flaps {flaps}",
      "read": "(A:FLAPS HANDLE INDEX,Number)",
      "on": "(>K:FLAPS_{flaps})",
      "expect": "{flaps}",
      "only_if": {
        "option": "takeoff.antiIce",
        "one_of": ["off"]
      }
    },
    {
      "label": "Dome off",
      "read": "(L:INI_CKPT_LT_DOME)",
      "on": "0 (>L:INI_CKPT_LT_DOME)",
      "expect": 0
    }
  ]
}
