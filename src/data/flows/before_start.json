{
  "id": "before_start",
  "name": "Before Start",
  "steps": [
    {
      "label": "Cockpit Door close",
      "read": "(L:INI_COCKPIT_DOOR)",
      "on": "0 (>L:INI_COCKPIT_DOOR)",
      "expect": 0
    },
    {
      "label": "Cockpit Door Lock",
      "read": "(L:INI_COCKPIT_DOOR_LOCK)",
      "on": "1 (>L:INI_COCKPIT_DOOR_LOCK)",
      "expect": 1
    },
    {
      "label": "HUD Deploy",
      "read": "(L:INI_HUD_RIGHT_STATE)",
      "on": "1 (>L:INI_HUD_RIGHT_STATE)",
      "expect": 1,
      "only_if": {
        "read": "(L:INI_IS_HUD)",
        "one_of": [1]
      }
    },
    {
      "label": "HUD Uncover",
      "read": "(L:INI_HUD_COVER_RIGHT)",
      "on": "0 (>L:INI_HUD_COVER_RIGHT)",
      "expect": 0,
      "only_if": {
        "read": "(L:INI_IS_HUD)",
        "one_of": [1]
      }
    },
    {
      "label": "HUD Bright on",
      "read": "(L:INI_HUD_BRIGHTNESS_RIGHT",
      "on": "70 (>L:INI_HUD_BRIGHTNESS_RIGHT)",
      "expect": 70,
      "only_if": {
        "read": "(L:INI_IS_HUD)",
        "one_of": [1]
      }
    },
    {
      "label": "SURV MCDU",
      "read": "(L:INI_MCDU2_SURV)",
      "on": "1 (>L:INI_MCDU2_SURV)",
      "expect": 1,
      "skip_verify": true
    }
  ]
}
