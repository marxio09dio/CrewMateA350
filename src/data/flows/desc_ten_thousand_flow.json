{
  "id": "desc_ten_thousand_flow",
  "name": "Descend Ten Thousand Flow",
  "steps": [
    {
      "label": "Landing Lights",
      "read": "(L:INI_LIGHTS_LANDING)",
      "on": "1 (>L:INI_LIGHTS_LANDING)",
      "expect": 1
    },
    {
      "label": "Logo Lights",
      "read": "(L:INI_LIGHTS_LOGO)",
      "on": "0 (>L:INI_LIGHTS_LOGO)",
      "expect": 0
    },
    {
      "label": "Nose Wheel Light",
      "read": "(L:INI_LIGHTS_NOSE)",
      "on": "1 (>L:INI_LIGHTS_NOSE)",
      "expect": 1
    },
    {
      "label": "FO LS",
      "read": "(L:INI_LS_FO)",
      "on": "1 (>L:INI_LS_FO)",
      "expect": 1
    }
  ]
}
