{
  "id": "desc_ten_thousand_flow",
  "name": "Descend Ten Thousand Flow",
  "steps": [
    {
      "label": "Table",
      "read": "(L:INI_FO_TRAY_COVER_TGT)",
      "on": "0 (>L:INI_FO_TRAY_COVER_TGT)",
      "expect": 0
    },
    {
      "label": "Landing Lights",
      "read": "(L:INI_LIGHTS_LANDING)",
      "on": "1 (>L:INI_LIGHTS_LANDING)",
      "expect": 1
    },
    {
      "label": "Nose Wheel Light",
      "read": "(L:INI_LIGHTS_NOSE)",
      "on": "1 (>L:INI_LIGHTS_NOSE)",
      "expect": 1
    },
    {
      "label": "Engine 1 Anti Ice",
      "read": "(L:INI_ENG_ANTI_ICE1_STATE)",
      "on": "{landing_anti_ice_eng1_cmd}",
      "expect": "{landing_anti_ice_eng1_expect}"
    },
    {
      "label": "Engine 2 Anti Ice",
      "read": "(L:INI_ENG_ANTI_ICE2_STATE)",
      "on": "{landing_anti_ice_eng2_cmd}",
      "expect": "{landing_anti_ice_eng2_expect}"
    },
    {
      "label": "Seat belts",
      "read": "(L:INI_SEATBELTS_SWITCH",
      "on": "2 (>L:INI_SEATBELTS_SWITCH)",
      "expect": 2
    },
    {
      "label": "Terrain Display",
      "read": "(L:INI_TERR_ON_FO)",
      "on": "1 (>L:INI_TERR_ON_FO)",
      "expect": 1
    },
    {
      "label": "FO LS",
      "read": "(L:INI_LS_FO)",
      "on": "1 (>L:INI_LS_FO)",
      "expect": 1,
      "only_if": {
        "read": "(L:INI_APPROACH_TYPE)",
        "one_of": [1, 2, 5, 6]
      }
    }
  ]
}
