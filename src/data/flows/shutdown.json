{
  "id": "shutdown",
  "name": "Shutdown",
  "steps": [
    {
      "label": "Engine 1 Anti Ice",
      "read": "(L:INI_ENG_ANTI_ICE1_STATE)",
      "on": "0 (L:INI_ENG_ANTI_ICE1_STATE)",
      "expect": 0
    },
    {
      "label": "Engine 2 Anti Ice",
      "read": "(L:INI_ENG_ANTI_ICE2_STATE)",
      "on": "0 (L:INI_ENG_ANTI_ICE2_STATE)",
      "expect": 0
    },
    {
      "label": "Wing Anti Ice",
      "read": "(L:INI_WING_ANTI_ICE1_STATE)",
      "on": "0 (L:INI_WING_ANTI_ICE1_STATE)",
      "expect": 0
    },
    {
      "label": "APU Bleed",
      "read": "(L:INI_AIR_BLEED_APU)",
      "on": "1 (>L:INI_AIR_BLEED_APU)",
      "expect": 1
    },
    {
      "label": "Right STBY Pump",
      "read": "(L:INI_OUTER_TANK_RIGHT)",
      "on": "0 (>L:INI_OUTER_TANK_RIGHT)",
      "expect": 0
    },
    {
      "label": "Right Main Pump",
      "read": "(L:INI_INNER_TANK_RIGHT)",
      "on": "0 (>L:INI_INNER_TANK_RIGHT)",
      "expect": 0
    },
    {
      "label": "Right center Pump",
      "read": "(L:INI_CENTER_TANK_RIGHT)",
      "on": "0 (>L:INI_CENTER_TANK_RIGHT)",
      "expect": 0
    },
    {
      "label": "Left center Pump",
      "read": "(L:INI_CENTER_TANK_LEFT)",
      "on": "0 (>L:INI_CENTER_TANK_LEFT)",
      "expect": 0
    },
    {
      "label": "Left STBY Pump",
      "read": "(L:INI_INNER_TANK_LEFT)",
      "on": "0 (>L:INI_INNER_TANK_LEFT)",
      "expect": 0
    },
    {
      "label": "Left Main Pump",
      "read": "(L:INI_OUTER_TANK_LEFT)",
      "on": "0 (>L:INI_OUTER_TANK_LEFT)",
      "expect": 0
    },
    {
      "label": "XPDR",
      "read": "(L:INI_TCAS_STBY_STATE)",
      "on": "0 (>L:INI_TCAS_STBY_STATE)",
      "expect": 0
    },

    {
      "label": "HUD Cover",
      "read": "(L:INI_HUD_COVER_RIGHT)",
      "on": "1 (>L:INI_HUD_COVER_RIGHT)",
      "expect": 1,
      "only_if": {
        "read": "(L:INI_IS_HUD)",
        "one_of": [1]
      }
    },
    {
      "label": "HUD Stow",
      "read": "(L:INI_HUD_RIGHT_STATE)",
      "on": "0 (>L:INI_HUD_RIGHT_STATE)",
      "expect": 0,
      "only_if": {
        "read": "(L:INI_IS_HUD)",
        "one_of": [1]
      }
    }
  ]
}
