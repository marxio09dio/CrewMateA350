{
  "id": "prelim_cockpit_prep",
  "name": "Preliminary Cockpit Preparation",
  "steps": [
    {
      "label": "Battery volts check",
      "read": "(L:INI_BATT_VOLTAGE_SELECTOR)",
      "on": "0 (>L:INI_BATT_VOLTAGE_SELECTOR)",
      "expect": 0,
      "wait_ms": 2500
    },
    {
      "label": "Battery volts check",
      "read": "(L:INI_BATT_VOLTAGE_SELECTOR)",
      "on": " 1 (>L:INI_BATT_VOLTAGE_SELECTOR)",
      "expect": 1,
      "wait_ms": 2500
    },
    {
      "label": "Battery volts check",
      "read": "(L:INI_BATT_VOLTAGE_SELECTOR)",
      "on": "3 (>L:INI_BATT_VOLTAGE_SELECTOR)",
      "expect": 3,
      "wait_ms": 2500
    },
    {
      "label": "Battery volts check",
      "read": "(L:INI_BATT_VOLTAGE_SELECTOR)",
      "on": "4 (>L:INI_BATT_VOLTAGE_SELECTOR)",
      "expect": 4,
      "wait_ms": 2500
    },
    {
      "label": "Battery volts check complete",
      "read": "(L:INI_BATT_VOLTAGE_SELECTOR)",
      "on": "2 (>L:INI_BATT_VOLTAGE_SELECTOR)",
      "expect": 2
    },
    {
      "label": "Battery 1 Switch",
      "read": "(L:INI_BATTERY_1_SWITCH)",
      "on": "1 (>L:INI_BATTERY_1_SWITCH)",
      "expect": 1
    },
    {
      "label": "Battery Emergency 1 Switch",
      "read": "(L:INI_BATTERY_EMER1_SWITCH)",
      "on": "1 (>L:INI_BATTERY_EMER1_SWITCH)",
      "expect": 1
    },
    {
      "label": "Battery Emergency 2 Switch",
      "read": "(L:INI_BATTERY_EMER2_SWITCH)",
      "on": "1 (>L:INI_BATTERY_EMER2_SWITCH)",
      "expect": 1
    },
    {
      "label": "Battery 2 Switch",
      "read": "(L:INI_BATTERY_2_SWITCH)",
      "on": "1 (>L:INI_BATTERY_2_SWITCH)",
      "expect": 1
    },
    {
      "label": "Ext Power B Switch",
      "read": "(L:INI_GEN_EXT_B_ONLINE)",
      "on": "1 (>L:INI_GEN_EXT_B_ONLINE)",
      "expect": 1
    },
    {
      "label": "Ext Power A Switch",
      "read": "(L:INI_GEN_EXT_A_ONLINE)",
      "on": "1 (>L:INI_GEN_EXT_A_ONLINE)",
      "expect": 1,
      "wait_ms": 20000
    },
    {
      "label": "IRS 1 NAV",
      "read": "(L:INI_IRS1_STATE)",
      "on": "1 (>L:INI_IRS1_STATE)",
      "expect": 1
    },
    {
      "label": "IRS 2 NAV",
      "read": "(L:INI_IRS2_STATE)",
      "on": "1 (>L:INI_IRS2_STATE)",
      "expect": 1
    },
    {
      "label": "IRS 3 NAV",
      "read": "(L:INI_IRS3_STATE)",
      "on": "1 (>L:INI_IRS3_STATE)",
      "expect": 1
    },
    {
      "label": "VHF RMP2 Receive Sel",
      "read": "(L:INI_RMP2_1_RECEIVE_SEL)",
      "on": "1 (>L:INI_RMP2_1_RECEIVE_SEL)",
      "expect": 1
    },
    {
      "label": "VHF RMP2 transmit Channel",
      "read": "(L:INI_RMP2_TRANSMIT_CHANNEL)",
      "on": "1 (>L:INI_RMP2_TRANSMIT_CHANNEL)",
      "expect": 1
    },
    {
      "label": "VHF RMP2 Volume",
      "read": "(L:INI_RMP2_1_VOLUME)",
      "on": "65 (>L:INI_RMP2_1_VOLUME)",
      "expect": 65
    },
    {
      "label": "VHF RMP2 Receive Sel",
      "read": "(L:INI_RMP2_8_RECEIVE_SEL)",
      "on": "1 (>L:INI_RMP2_8_RECEIVE_SEL)",
      "expect": 1
    },
    {
      "label": "VHF RMP2 Volume",
      "read": "(L:INI_RMP2_8_VOLUME)",
      "on": "65 (>L:INI_RMP2_8_VOLUME)",
      "expect": 65
    },
    {
      "label": "VHF RMP2 Receive Sel",
      "read": "(L:INI_RMP2_9_RECEIVE_SEL)",
      "on": "1 (>L:INI_RMP2_9_RECEIVE_SEL)",
      "expect": 1
    },
    {
      "label": "VHF RMP2 Volume",
      "read": "(L:INI_RMP2_9_VOLUME)",
      "on": "65 (>L:INI_RMP2_9_VOLUME)",
      "expect": 65
    },
    {
      "label": "VHF RMP11 Receive Sel",
      "read": "(L:INI_RMP2_11_RECEIVE_SEL)",
      "on": "1 (>L:INI_RMP2_11_RECEIVE_SEL)",
      "expect": 1
    },
    {
      "label": "VHF RMP11 Volume",
      "read": "(L:INI_RMP2_11_VOLUME)",
      "on": "65 (>L:INI_RMP2_11_VOLUME)",
      "expect": 65
    },
    {
      "label": "Dome on",
      "read": "(L:INI_CKPT_LT_DOME)",
      "on": "100 (>L:INI_CKPT_LT_DOME)",
      "expect": 100,
      "only_if": {
        "read": "(E:TIME OF DAY)",
        "one_of": [0, 2, 3]
      }
    },
    {
      "label": "Stby Compass Light",
      "read": "(L:INI_LIGHTS_STBY_COMPASS)",
      "on": "0 (>L:INI_LIGHTS_STBY_COMPASS)",
      "expect": 0
    },
    {
      "label": "Fire Test",
      "read": "(L:INI_FIRE_TEST)",
      "on": "1 (>L:INI_FIRE_TEST)",
      "hold_ms": 6000,
      "expect": 1,
      "skip_verify": true,
      "sound_on_execute": "fire_test.ogg"
    }
  ]
}
