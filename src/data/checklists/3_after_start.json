{
  "id": "after_start",
  "name": "After Start",
  "items": [
    {
      "label": "Anti Ice",
      "challenge": "anti_ice.ogg",
      "response": ["engines on", "engines on wings on", "off", "set and checked"],
      "incorrect": "are_you_sure.ogg",
      "validations": [
        {
          "when": { "responses": ["off"] },
          "checks": [
            { "type": "store", "store": "takeoff.antiIce", "equals": "off" },
            { "type": "simvar", "var": "(L:INI_ENG_ANTI_ICE1_STATE)", "expected": 0 },
            { "type": "simvar", "var": "(L:INI_ENG_ANTI_ICE2_STATE)", "expected": 0 },
            { "type": "simvar", "var": "(L:INI_WING_ANTI_ICE1_STATE)", "expected": 0 }
          ]
        },
        {
          "when": { "responses": ["engines on"] },
          "checks": [
            { "type": "store", "store": "takeoff.antiIce", "equals": "oneng" },
            { "type": "simvar", "var": "(L:INI_ENG_ANTI_ICE1_STATE)", "expected": 1 },
            { "type": "simvar", "var": "(L:INI_ENG_ANTI_ICE2_STATE)", "expected": 1 },
            { "type": "simvar", "var": "(L:INI_WING_ANTI_ICE1_STATE)", "expected": 0 }
          ]
        },
        {
          "when": { "responses": ["engines on wings on"] },
          "checks": [
            { "type": "store", "store": "takeoff.antiIce", "equals": "onengwing" },
            { "type": "simvar", "var": "(L:INI_ENG_ANTI_ICE1_STATE)", "expected": 1 },
            { "type": "simvar", "var": "(L:INI_ENG_ANTI_ICE2_STATE)", "expected": 1 },
            { "type": "simvar", "var": "(L:INI_WING_ANTI_ICE1_STATE)", "expected": 1 }
          ]
        },
        {
          "when": { "responses": ["set and checked"] },
          "checks": [
            {
              "type": "any",
              "groups": [
                [
                  { "type": "store", "store": "takeoff.antiIce", "equals": "off" },
                  { "type": "simvar", "var": "(L:INI_ENG_ANTI_ICE1_STATE)", "expected": 0 },
                  { "type": "simvar", "var": "(L:INI_ENG_ANTI_ICE2_STATE)", "expected": 0 },
                  { "type": "simvar", "var": "(L:INI_WING_ANTI_ICE1_STATE)", "expected": 0 }
                ],
                [
                  { "type": "store", "store": "takeoff.antiIce", "equals": "oneng" },
                  { "type": "simvar", "var": "(L:INI_ENG_ANTI_ICE1_STATE)", "expected": 1 },
                  { "type": "simvar", "var": "(L:INI_ENG_ANTI_ICE2_STATE)", "expected": 1 },
                  { "type": "simvar", "var": "(L:INI_WING_ANTI_ICE1_STATE)", "expected": 0 }
                ],
                [
                  { "type": "store", "store": "takeoff.antiIce", "equals": "onengwing" },
                  { "type": "simvar", "var": "(L:INI_ENG_ANTI_ICE1_STATE)", "expected": 1 },
                  { "type": "simvar", "var": "(L:INI_ENG_ANTI_ICE2_STATE)", "expected": 1 },
                  { "type": "simvar", "var": "(L:INI_WING_ANTI_ICE1_STATE)", "expected": 1 }
                ]
              ]
            }
          ]
        }
      ]
    },
    {
      "challenge": "flight_controls.ogg",
      "response": ["checked", "set and checked"],
      "label": "Flight Controls",
      "copilot_confirmation": "checked.ogg"
    },
    {
      "challenge": "ground_clearance.ogg",
      "response": ["received", "set and checked"],
      "label": "Ground Clearance"
    }
  ],
  "completion": "after_start_checklist_completed.ogg"
}
